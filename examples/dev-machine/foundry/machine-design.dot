// machine-design.dot -- Founding Session Pipeline
//
// Translates the /machine-design mode (143 lines) + machine-designer agent (63 lines)
// into a DOT pipeline.
//
// First checks for a passing admissions assessment (.dev-machine-assessment.md).
// If no assessment exists, exits immediately with a message to run /admissions first.
// If the assessment exists, runs 6 convergence-factory phases to produce all
// machine design artifacts.
//
// Phases:
//   Phase 1: Configuration & Naming    -- Gathers machine configuration variables
//   Phase 2: Feature Decomposition     -- Architecture spec and first feature specs
//   Phase 3: Script Design             -- Module specs and pipeline script design
//   Phase 4: DOT Pipeline Design       -- DOT pipeline files for the runtime machine
//   Phase 5: Design Document Assembly  -- Compiles .dev-machine-design.md
//   Phase 6: Manifest Generation       -- Generates the machine manifest
//
// Assessment routing:
//   assessment_exists=false -> done_no_assessment  (early exit)
//   assessment_exists=true  -> phase1_config       (proceed with founding session)
//
// Node count: 11 (start + assessment_check + assessment_gate + 6 phases + done_complete + done_no_assessment)
// Edge count: 10 (start->check->gate + 2 conditional from gate + 5 sequential between phases + phase6->done_complete)
//
// Source material:
//   amplifier-bundle-dev-machine/modes/machine-design.md
//   amplifier-bundle-dev-machine/agents/machine-designer.md

digraph MachineDesign {
    graph [label="Dev Machine Design: Founding Session Pipeline"]
    rankdir=TB

    // -----------------------------------------------------------------------
    // Entry point
    // -----------------------------------------------------------------------

    start [shape=Mdiamond, label="Start"]

    // -----------------------------------------------------------------------
    // Assessment check (tool/parallelogram)
    // Checks whether .dev-machine-assessment.md exists; outputs JSON with
    // assessment_exists: true or false.
    // -----------------------------------------------------------------------

    assessment_check [
        shape=parallelogram,
        label="Check Assessment",
        tool_command="test -f .dev-machine-assessment.md && echo '{\"assessment_exists\": true}' || echo '{\"assessment_exists\": false}'",
        parse_json=true
    ]

    // -----------------------------------------------------------------------
    // Assessment gate (diamond) -- routes by context.assessment_exists
    // -----------------------------------------------------------------------

    assessment_gate [shape=diamond, label="Assessment Exists?"]

    // -----------------------------------------------------------------------
    // Phase 1: Configuration & Naming
    // Source: machine-design.md Phase 1 "Gather Machine Configuration"
    // -----------------------------------------------------------------------

    phase1_config [
        shape=folder,
        label="Phase 1: Configuration & Naming",
        dot_file="../../patterns/convergence-factory.dot",
        context.artifact_goal="Collect the required machine Configuration variables through conversation with the user.\n\nRead @dev-machine:context/pattern.md for the full pattern reference.\nRead @dev-machine:context/templates-reference.md for template variables.\n\n1. Project basics:\n   - project_name: short identifier\n   - project_dir: absolute path\n   - Technology stack overview\n\n2. Build/test toolchain:\n   - build_command: what builds/compiles the project\n   - test_command: what runs tests\n   - type_check_command: separate type checker (if any)\n   - Verify these commands work by running them\n\n3. Spec infrastructure:\n   - specs_dir: where specs will live\n   - architecture_spec: path for the architecture spec\n\n4. Machine tuning:\n   - max_features_per_session: features per session (default: 3-5)\n   - max_outer_iterations: max outer loop iterations (default: 50)\n   - module_size_threshold: LOC limit per module (default: 10000)\n   - qa_enabled: whether QA machine is needed\n\nWrite the machine Configuration to .ai/phase1-machine-config.md.",
        context.artifact_path=".ai/phase1-machine-config.md",
        context.max_cycles=3
    ]

    // -----------------------------------------------------------------------
    // Phase 2: Feature Decomposition
    // Source: machine-design.md Phase 2 + Phase 4
    //   "Architecture Spec (The Constitution)" + "First Batch of Feature Specs"
    // -----------------------------------------------------------------------

    phase2_decomposition [
        shape=folder,
        label="Phase 2: Feature Decomposition",
        dot_file="../../patterns/convergence-factory.dot",
        context.artifact_goal="Guide the user through architecture and Feature decomposition.\n\nRead @dev-machine:context/pattern.md for the full pattern reference.\n\n### Architecture Spec (The Constitution)\n\nGuide the user through writing or reviewing their architecture spec. It must cover:\n\n1. Data model -- core types and data structures\n2. Module boundaries -- what modules exist, their responsibilities, interfaces between them\n3. Technology choices -- language, framework, key libraries, with rationale\n4. Key patterns -- state management, data flow, error handling, testing approach\n5. Build/test/deploy -- how the project is built, tested, and (eventually) deployed\n\nThe architecture spec should be:\n- Complete enough to prevent drift across hundreds of features\n- Concise enough for an agent to read in <2 minutes\n- Written for machine consumption (explicit interfaces, not hand-wavy descriptions)\n\nIf the user has existing architecture docs, review and assess them. Suggest additions if needed.\n\nWrite the architecture spec to {{specs_dir}}/architecture.md.\n\n### Feature Decomposition\n\nWrite the first batch of Feature specs (5-15 features) covering the bootstrap/foundation work.\nUse the template from @dev-machine:templates/feature-spec-template.md.\n\nWrite Feature specs to {{specs_dir}}/features/<module>/<feature-id>.md.\n\nWrite the Feature decomposition summary to .ai/phase2-feature-decomposition.md.",
        context.artifact_path=".ai/phase2-feature-decomposition.md",
        context.max_cycles=3
    ]

    // -----------------------------------------------------------------------
    // Phase 3: Script Design
    // Source: machine-design.md Phase 3 "Module Specs"
    // -----------------------------------------------------------------------

    phase3_scripts [
        shape=folder,
        label="Phase 3: Script Design",
        dot_file="../../patterns/convergence-factory.dot",
        context.artifact_goal="For each major module identified in the architecture, design the module specs and pipeline Script files.\n\nRead @dev-machine:context/pattern.md for the full pattern reference.\n\n### Module Specs\n\nFor each major module identified in the architecture:\n- Define internal architecture\n- Define public API and contracts with adjacent modules\n- Define test strategy\n\nWrite module specs to {{specs_dir}}/modules/<module-name>.md.\n\n### Pipeline Script Design\n\nFor each module, design the pipeline Script files that support the runtime machine:\n- Build and test Script for the module (build-check.py or similar)\n- Health check Script (module-health-check.py)\n- Any module-specific pipeline Script helpers\n\nEach Script should:\n- Have a clear single responsibility\n- Accept inputs via environment variables or arguments\n- Output structured results for pipeline consumption\n- Be idempotent and safe to run in a fresh session\n\nWrite the Script design to .ai/phase3-script-design.md.",
        context.artifact_path=".ai/phase3-script-design.md",
        context.max_cycles=3
    ]

    // -----------------------------------------------------------------------
    // Phase 4: DOT Pipeline Design
    // Source: machine-design.md -- designing the runtime pipeline DOT files
    // -----------------------------------------------------------------------

    phase4_pipeline [
        shape=folder,
        label="Phase 4: DOT Pipeline Design",
        dot_file="../../patterns/convergence-factory.dot",
        context.artifact_goal="Design the DOT Pipeline files for the development machine runtime.\n\nRead @dev-machine:context/pattern.md for the full DOT pipeline pattern reference.\nRead @dev-machine:context/templates-reference.md for template variables.\n\nUsing the Attractor pipeline framework, design the following DOT Pipeline files:\n\n1. runtime/iteration.dot    -- The main feature implementation loop\n2. runtime/qa.dot           -- QA validation pipeline\n3. runtime/post-session.dot -- Post-session accounting and archiving\n4. runtime/health-check.dot -- Machine health monitoring pipeline\n5. runtime/smoke-test.dot   -- Smoke test pipeline for fast feedback\n\nFor each DOT Pipeline file:\n- Identify the nodes required (tool nodes, codergen nodes, diamond gates)\n- Design the edge flow and conditional routing\n- Reference appropriate reusable patterns from examples/patterns/\n- Ensure the Pipeline integrates with the build/test/type-check commands\n\nWrite the DOT Pipeline design to .ai/phase4-pipeline-design.md.",
        context.artifact_path=".ai/phase4-pipeline-design.md",
        context.max_cycles=3
    ]

    // -----------------------------------------------------------------------
    // Phase 5: Design Document Assembly
    // Source: machine-design.md Phase 5 "Machine Design Document"
    // Writes .dev-machine-design.md at the project root.
    // -----------------------------------------------------------------------

    phase5_design [
        shape=folder,
        label="Phase 5: Design Document Assembly",
        dot_file="../../patterns/convergence-factory.dot",
        context.artifact_goal="Compile all founding session decisions into .dev-machine-design.md at the project root.\n\nRead @dev-machine:context/pattern.md for the full pattern reference.\nRead .ai/phase1-machine-config.md, .ai/phase2-feature-decomposition.md,\n     .ai/phase3-script-design.md, and .ai/phase4-pipeline-design.md\nfor the outputs of earlier phases.\n\nWrite the complete design document to .dev-machine-design.md using this format:\n\n# {{project_name}} Development Machine Design\n\n## Machine Configuration\n\n| Variable | Value |\n|----------|-------|\n| project_name | ... |\n| project_dir | ... |\n| build_command | ... |\n| test_command | ... |\n| ... | ... |\n\n## Architecture Summary\n[Brief summary with pointer to full spec]\n\n## Module Inventory\n[List of modules with status]\n\n## Initial Feature Backlog\n[List of first-batch features]\n\n## QA Configuration\n[If qa_enabled: what to test and how]\n\n## Bootstrap Plan\n[What needs to happen before the machine can start running]\n\nThe artifact is the file .dev-machine-design.md itself.",
        context.artifact_path=".dev-machine-design.md",
        context.max_cycles=3
    ]

    // -----------------------------------------------------------------------
    // Phase 6: Manifest Generation
    // Source: machine-design.md Phase 6 "Wrap Up"
    // Generates the machine Manifest and calls mode(clear).
    // -----------------------------------------------------------------------

    phase6_manifest [
        shape=folder,
        label="Phase 6: Manifest Generation",
        dot_file="../../patterns/convergence-factory.dot",
        context.artifact_goal="Generate the machine Manifest and wrap up the founding session.\n\nRead @dev-machine:context/pattern.md for the full pattern reference.\nRead .dev-machine-design.md and all .ai/phase*.md files.\n\nGenerate the machine Manifest file at .ai/phase6-manifest.md listing:\n- All specs created (architecture, module specs, feature specs)\n- Machine configuration variables collected\n- Pipeline files to be generated by /generate-machine\n- Bootstrap sequence: what needs to happen before the machine can start running\n\nThe Manifest format:\n\n# Development Machine Manifest\n\n## Artifacts Created\n[List all files created during the founding session]\n\n## Machine Configuration\n[Key variables collected]\n\n## Pending Pipeline Files\n[DOT pipeline files to be generated by /generate-machine]\n\n## Bootstrap Sequence\n[Ordered list of bootstrap tasks]\n\n## Next Steps\nRun /generate-machine to generate the machine artifacts.\n\nAfter writing the Manifest, tell the user:\n1. What was created (architecture spec, module specs, feature specs, design doc)\n2. 'Run /generate-machine to generate the machine artifacts'\n\nCall mode(operation='clear') when done.\nCRITICAL: Call mode(clear) BEFORE outputting the wrap-up summary.",
        context.artifact_path=".ai/phase6-manifest.md",
        context.max_cycles=3
    ]

    // -----------------------------------------------------------------------
    // Terminal nodes (Msquare)
    // -----------------------------------------------------------------------

    done_complete     [shape=Msquare, label="Machine Design Complete: Run /generate-machine"]
    done_no_assessment [shape=Msquare, label="No Assessment Found: Run /admissions first"]

    // -----------------------------------------------------------------------
    // Sequential flow
    // -----------------------------------------------------------------------

    start             -> assessment_check
    assessment_check  -> assessment_gate

    // -----------------------------------------------------------------------
    // Assessment gate routing (2 conditional edges)
    // -----------------------------------------------------------------------

    assessment_gate -> done_no_assessment [label="no_assessment", condition="context.assessment_exists=false"]
    assessment_gate -> phase1_config      [label="proceed",       condition="context.assessment_exists=true"]

    // -----------------------------------------------------------------------
    // Phase chain: phase1 -> phase2 -> phase3 -> phase4 -> phase5 -> phase6 -> done
    // -----------------------------------------------------------------------

    phase1_config      -> phase2_decomposition
    phase2_decomposition -> phase3_scripts
    phase3_scripts     -> phase4_pipeline
    phase4_pipeline    -> phase5_design
    phase5_design      -> phase6_manifest
    phase6_manifest    -> done_complete
}
