// fix-iteration.dot -- Single Fix Cycle for the Health Check Loop
//
// Translates dev-machine-fix-iteration.yaml into a DOT pipeline.
// Called by health-check.dot fix_loop (shape=house) per cycle.
// Each invocation:
//   1. read_errors:  read SCRATCH.md to understand current errors (bash)
//   2. fix_session:  spawn a fresh agent session to fix them (box/LLM)
//   3. verify:       re-run build + test, update SCRATCH.md, output status
//
// Returns JSON so the outer manager loop can decide whether to continue
// looping or exit based on the verify step output.
//
// 5 nodes, 4 edges. Linear chain, no branching.
// Context variables: $project_dir, $build_command, $test_command,
//   $build_timeout, $max_fix_iterations, $iteration

digraph FixIteration {
    graph [label="Dev Machine Fix Iteration Sub-Pipeline"]
    rankdir=TB

    // -----------------------------------------------------------------------
    // Structural nodes
    // -----------------------------------------------------------------------

    start [shape=Mdiamond, label="Start"]
    done  [shape=Msquare,  label="Done"]

    // -----------------------------------------------------------------------
    // Step 1: Read current errors from SCRATCH.md
    // Increments the iteration counter and captures build error context.
    // parse_json='true' injects error_context into pipeline context.
    // continue_on_fail='true' so a missing SCRATCH.md does not halt the loop.
    // -----------------------------------------------------------------------

    read_errors [
        shape=parallelogram,
        label="Read Errors",
        tool_command="bash -c 'cd $project_dir && ITER=$(($iteration + 1)) && echo \"{\\\"iteration\\\": \\\"$ITER\\\", \\\"scratch\\\": \\\"see SCRATCH.md\\\"}\"'",
        parse_json="true",
        continue_on_fail="true"
    ]

    // -----------------------------------------------------------------------
    // Step 2: Fresh agent session to fix the errors
    // Dispatches a fresh agent with safety-constrained prompt.
    // context_fidelity=truncate keeps token budget manageable.
    // VERBATIM prompt from dev-machine-fix-iteration.yaml fix-session step
    // with template variable tokens adapted to $variable notation.
    // -----------------------------------------------------------------------

    fix_session [
        shape=box,
        context_fidelity="truncate",
        label="Fix Session",
        prompt="You are a HEALTH CHECK FIX SESSION for the $project_name project.
Working directory: $project_dir
This is fix iteration $iteration.

YOUR MISSION: Fix all build errors and test failures.

START BY READING:
1. ./SCRATCH.md -- contains the specific errors found by the health check
2. The specific files mentioned in the error output

FIXING STRATEGY:
- Parse each error from SCRATCH.md
- Group errors by file
- For each file:
  * Read the file
  * Fix ALL errors in that file at once
  * After fixing each file, run: $build_command 2>&1 | tail -20
  * Verify the errors in that file are resolved before moving on

VALIDATION:
- After all files are fixed, run: $build_command 2>&1
- Then run: $test_command 2>&1
- If build still fails, keep fixing (iterate on remaining errors)
- If tests fail, read the test output and fix the failures

COMMIT:
- Once build and tests pass, commit:
  git add -A && git commit -m 'fix: resolve build errors and test failures (health-check iteration $iteration)'

UPDATE SCRATCH.md:
- Append a section: ## Iteration $iteration -- Fixes Applied
- List what you fixed and the final build/test status

IMPORTANT:
- Do NOT add new features. Only fix existing errors.
- Do NOT refactor unless required to fix an error.
- Be surgical -- minimal changes to resolve each error.
- If you cannot fix an error, document it in SCRATCH.md as a known issue.

## SAFETY CONSTRAINTS (MANDATORY -- NEVER VIOLATE)
- Your working directory is $project_dir. Do NOT read, write, or execute commands on files outside this directory.
- FORBIDDEN commands: rm -rf, find -delete, any command targeting paths outside your working directory
- Do NOT cd to .., ~, /, or any path outside $project_dir
- Do NOT access: ~/.ssh/, ~/.amplifier/keys.env, .env files, *.pem, *.key, or any credential files
- Do NOT run: git push, git remote add, or any command that sends code to a remote repository
- Do NOT start background processes with &, nohup, or disown unless the recipe infrastructure started them
- Do NOT install global packages (pip install without venv, npm install -g)
- If you need something outside these boundaries, add a blocker to $state_file and STOP.
- VIOLATION OF THESE CONSTRAINTS MAY CAUSE DATA LOSS ACROSS THE ENTIRE DEVELOPMENT ENVIRONMENT."
    ]

    // -----------------------------------------------------------------------
    // Step 3: Verify -- re-run build + test, update SCRATCH.md, output status
    // Checks whether the fix session resolved all errors.
    // parse_json='true' injects verify status into context for outer loop.
    // continue_on_fail='true' so build failures are captured as JSON.
    // -----------------------------------------------------------------------

    verify [
        shape=parallelogram,
        label="Verify",
        tool_command="bash -c 'cd $project_dir && BUILD_OUTPUT=$(${build_command} 2>&1) || true; BUILD_EXIT=$?; TEST_OUTPUT=$(${test_command} 2>&1) || true; TEST_EXIT=$?; if [ $BUILD_EXIT -eq 0 ] && [ $TEST_EXIT -eq 0 ]; then echo \"{\\\"status\\\": \\\"done\\\", \\\"iteration\\\": \\\"$iteration\\\"}\"; else echo \"{\\\"status\\\": \\\"checking\\\", \\\"iteration\\\": \\\"$iteration\\\"}\"; fi'",
        parse_json="true",
        continue_on_fail="true"
    ]

    // -----------------------------------------------------------------------
    // Edges (4 total) -- linear chain, no branching
    // -----------------------------------------------------------------------

    start       -> read_errors
    read_errors -> fix_session
    fix_session -> verify
    verify      -> done
}
