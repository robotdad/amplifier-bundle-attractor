// qa-iteration.dot -- Single Iteration of the QA Machine Loop
//
// Translates dev-machine-qa-iteration.yaml (148 lines) into a DOT pipeline.
// Called by qa.dot qa_loop (shape=house) per cycle.
// Each invocation:
//   1. orient:         read QA-STATE.yaml, find next untested area (bash)
//   2. orient_gate:    route on status: testing -> qa_session, done/blocked -> done
//   3. qa_session:     fresh QA agent session -- test one area, fix if broken (box/LLM)
//   4. post_qasession: re-read QA-STATE.yaml, output status for outer loop (bash)
//
// Returns structured JSON so the outer manager loop can decide whether to
// continue looping or exit based on outcome.
//
// 6 nodes, 7 edges.
// Context variables: $project_dir, $qa_state_file, $qa_context_file,
//   $test_command, $build_command, $project_name, $next_test

digraph QAIteration {
    graph [label="Dev Machine QA Iteration Sub-Pipeline"]
    rankdir=TB

    // -----------------------------------------------------------------------
    // Structural nodes
    // -----------------------------------------------------------------------

    start [shape=Mdiamond, label="Start"]
    done  [shape=Msquare,  label="Done"]

    // -----------------------------------------------------------------------
    // Step 1: Orient -- read QA-STATE.yaml, find next untested area
    // Reads the QA state file and determines what to test next.
    // parse_json='true' injects orient_state (next_test, status) into context.
    // -----------------------------------------------------------------------

    orient [
        shape=parallelogram,
        label="Orient",
        tool_command="bash -c 'cd $project_dir && python3 -c \"\nimport json, yaml, sys\ntry:\n    with open(\\\"$qa_state_file\\\") as f:\n        state = yaml.safe_load(f)\n    test_areas = state.get(\\\"test_areas\\\", {})\n    for name, info in test_areas.items():\n        if info.get(\\\"status\\\") in (\\\"not-tested\\\", \\\"failing\\\"):\n            print(json.dumps({\\\"next_test\\\": name, \\\"status\\\": \\\"testing\\\", \\\"all_areas\\\": list(test_areas.keys())}))\n            sys.exit(0)\n    print(json.dumps({\\\"next_test\\\": None, \\\"status\\\": \\\"done\\\"}))\nexcept Exception as e:\n    print(json.dumps({\\\"status\\\": \\\"blocked\\\", \\\"error\\\": str(e)}))\n\"'",
        parse_json="true"
    ]

    // -----------------------------------------------------------------------
    // Step 2: Orient gate -- check status from orient step
    // Routes testing sessions to qa_session.
    // Routes done or blocked sessions directly to done.
    // -----------------------------------------------------------------------

    orient_gate [
        shape=diamond,
        label="Status?"
    ]

    // -----------------------------------------------------------------------
    // Step 3: Fresh QA agent session -- test one area, fix if broken
    // Dispatches a fresh agent with zero prior context.
    // context_fidelity=truncate keeps token budget manageable.
    // VERBATIM prompt from dev-machine-qa-iteration.yaml qa-session step
    // (lines 67-107) with {{variable}} -> $variable adaptation.
    // -----------------------------------------------------------------------

    qa_session [
        shape=box,
        context_fidelity="truncate",
        label="QA Session",
        prompt="You are a QA TESTING SESSION for the $project_name project.
You start with ZERO prior context. Your job: test one area, fix if broken, persist state, exit.
Working directory: $project_dir

START BY READING THESE FILES (in this order):
1. $qa_state_file -- what's been tested, what's next
2. $qa_context_file -- previous QA findings

## Current Test Target
Area/Case: $next_test

## Your Mission
1. Test the area described in the QA state file
2. If broken: read the relevant source files, fix the issue, re-test
3. Run $test_command && $build_command after any code changes
4. Commit fixes: fix(<module>): QA -- <description>

## State Persistence (CRITICAL)
After testing the area/case:
- Update $qa_state_file: mark the area as \"passing\" or \"failing\" with issues list
- Update $qa_context_file with findings
- If you fixed code: commit immediately

## When to Stop
- You've tested the current area and either it passes or you've fixed it
- You encounter a blocker you can't resolve -- add it to blockers in $qa_state_file
- Stop gracefully -- the outer recipe will continue with the next area

## SAFETY CONSTRAINTS (MANDATORY -- NEVER VIOLATE)
- Your working directory is $project_dir. Do NOT read, write, or execute commands on files outside this directory.
- FORBIDDEN commands: rm -rf, find -delete, any command targeting paths outside your working directory
- Do NOT cd to .., ~, /, or any path outside $project_dir
- Do NOT access: ~/.ssh/, ~/.amplifier/keys.env, .env files, *.pem, *.key, or any credential files
- Do NOT run: git push, git remote add, or any command that sends code to a remote repository
- Do NOT start background processes with &, nohup, or disown unless the recipe infrastructure started them
- Do NOT install global packages (pip install without venv, npm install -g)
- If you need something outside these boundaries, add a blocker to $qa_state_file and STOP.
- VIOLATION OF THESE CONSTRAINTS MAY CAUSE DATA LOSS ACROSS THE ENTIRE DEVELOPMENT ENVIRONMENT."
    ]

    // -----------------------------------------------------------------------
    // Step 4: Post-QA-session -- re-read QA-STATE.yaml, output status
    // Checks whether all areas are now passing, or if there are blockers,
    // or if there are still areas to test.
    // parse_json='true' injects post_result into context for outer loop.
    // -----------------------------------------------------------------------

    post_qasession [
        shape=parallelogram,
        label="Post QA Session",
        tool_command="bash -c 'cd $project_dir && python3 -c \"\nimport json, yaml\ntry:\n    with open(\\\"$qa_state_file\\\") as f:\n        state = yaml.safe_load(f)\n    blockers = state.get(\\\"blockers\\\", [])\n    test_areas = state.get(\\\"test_areas\\\", {})\n    all_passing = all(a.get(\\\"status\\\") == \\\"passing\\\" for a in test_areas.values())\n    any_untested = any(a.get(\\\"status\\\") in (\\\"not-tested\\\", \\\"failing\\\") for a in test_areas.values())\n    if all_passing:\n        status = \\\"done\\\"\n    elif blockers:\n        status = \\\"blocked\\\"\n    elif any_untested:\n        status = \\\"testing\\\"\n    else:\n        status = \\\"done\\\"\n    print(json.dumps({\\\"status\\\": status}))\nexcept Exception as e:\n    print(json.dumps({\\\"status\\\": \\\"blocked\\\", \\\"error\\\": str(e)}))\n\"'",
        parse_json="true"
    ]

    // -----------------------------------------------------------------------
    // Edges (7 total)
    // -----------------------------------------------------------------------

    // Entry
    start -> orient

    // orient produces context.status = testing|done|blocked
    orient -> orient_gate

    // Gate: testing -> run QA session for the next area
    orient_gate -> qa_session    [label="testing", condition="context.status=testing"]
    // Gate: done -> all areas tested, exit
    orient_gate -> done          [label="done",    condition="context.status=done"]
    // Gate: blocked -> cannot proceed, exit
    orient_gate -> done          [label="blocked", condition="context.status=blocked"]

    // QA session -> post-session check
    qa_session -> post_qasession

    // Post-session -> done (outer loop reads post_result for next decision)
    post_qasession -> done
}
