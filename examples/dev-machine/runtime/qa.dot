// qa.dot -- The QA Machine Outer Loop
//
// Translates dev-machine-qa.yaml (153 lines) into a DOT pipeline.
// Runs the QA machine: visual fidelity and interactive correctness testing.
//
// Each QA session starts with zero context, reads QA-STATE.yaml and
// QA-CONTEXT-TRANSFER.md, tests one area, persists state, and exits.
//
// Only used when qa_enabled is true during machine design.
//
// Flow:
//   1. container_check:  refuse to run on bare host (hard-fail)
//   2. read_qa_state:    read QA-STATE.yaml, parse JSON, check for blockers
//   3. blocked_gate:     if blocked, exit done; if testing, enter qa_loop
//   4. qa_loop:          manager loop running qa-iteration.dot per cycle
//                        until outcome=success or max 20 cycles exhausted
//   5. final_summary:    print final QA machine run summary (continue_on_fail)
//
// 7 nodes, 7 edges.
// Context variables: $project_dir, $qa_state_file, $qa_context_file,
//   $test_command, $build_command, $project_name

digraph QA {
    graph [label="Dev Machine QA Loop Pipeline"]
    rankdir=TB

    // -----------------------------------------------------------------------
    // Structural nodes
    // -----------------------------------------------------------------------

    start [shape=Mdiamond, label="Start"]
    done  [shape=Msquare,  label="Done"]

    // -----------------------------------------------------------------------
    // Step 0: Container safety check -- refuse to run on bare host
    // Verifies the recipe is running inside a container before allowing
    // autonomous agents to execute. Hard-fail: if not in a container and
    // DEV_MACHINE_ALLOW_HOST is unset, the pipeline stops immediately.
    // -----------------------------------------------------------------------

    container_check [
        shape=parallelogram,
        label="Container Check",
        tool_command="bash -c 'if [ ! -f /.dockerenv ] && [ ! -f /run/.containerenv ]; then if [ -z \"${DEV_MACHINE_ALLOW_HOST:-}\" ]; then echo \"ERROR: DEV MACHINE NOT RUNNING IN CONTAINER. Use ./run-dev-machine.sh\"; exit 1; fi; echo \"WARNING: DEV_MACHINE_ALLOW_HOST is set. Proceeding on bare host.\"; fi; echo \"Container check passed.\"'"
    ]

    // -----------------------------------------------------------------------
    // Step 1: Read QA-STATE.yaml and check for blockers
    // Reads the QA state file, parses JSON output to get status/phase/blockers.
    // parse_json='true' injects initial_state into context for blocked_gate.
    // -----------------------------------------------------------------------

    read_qa_state [
        shape=parallelogram,
        label="Read QA State",
        tool_command="bash -c 'cd $project_dir && python3 -c \"\nimport json, yaml, sys\ntry:\n    with open(\\\"$qa_state_file\\\") as f:\n        state = yaml.safe_load(f)\n    blockers = state.get(\\\"blockers\\\", [])\n    result = {\n        \\\"phase\\\": state.get(\\\"phase\\\", \\\"visual-fidelity\\\"),\n        \\\"epoch\\\": state.get(\\\"epoch\\\", 0),\n        \\\"blocker_count\\\": len(blockers),\n        \\\"blockers\\\": blockers,\n        \\\"next_action\\\": state.get(\\\"next_action\\\", \\\"\\\"),\n        \\\"status\\\": \\\"blocked\\\" if blockers else \\\"testing\\\"\n    }\n    print(json.dumps(result))\nexcept Exception as e:\n    print(json.dumps({\\\"status\\\": \\\"blocked\\\", \\\"blockers\\\": [\\\"Failed to read QA state: \\\" + str(e)], \\\"blocker_count\\\": 1}))\n\"'",
        parse_json="true"
    ]

    // -----------------------------------------------------------------------
    // Step 2: Blocked gate -- check if QA can proceed
    // Routes blocked sessions to done (unresolvable without human intervention)
    // or testing sessions to the qa_loop.
    // -----------------------------------------------------------------------

    blocked_gate [
        shape=diamond,
        label="Blocked?"
    ]

    // -----------------------------------------------------------------------
    // Step 3: QA loop -- manager loop over qa-iteration.dot
    // Runs qa-iteration.dot per cycle until outcome=success or
    // max 20 cycles exhausted. Uses manager.stop_condition='outcome=success'
    // to exit as soon as all QA areas pass.
    // manager.child_dotfile delegates each cycle to qa-iteration.dot.
    // -----------------------------------------------------------------------

    qa_loop [
        shape=house,
        label="QA Loop",
        manager.max_cycles="20",
        manager.stop_condition="outcome=success",
        manager.child_dotfile=".dev-machine/runtime/qa-iteration.dot"
    ]

    // -----------------------------------------------------------------------
    // Step 4: Final QA summary -- aggregate results, print report
    // Prints a summary of all QA sessions completed, final status, and
    // state file location. continue_on_fail='true' so a partial run still
    // prints a summary even if the last session errored.
    // -----------------------------------------------------------------------

    final_summary [
        shape=parallelogram,
        label="Final Summary",
        tool_command="bash -c 'cd $project_dir && echo \"\" && echo \"======================================\" && echo \"  $project_name QA Machine: Run Complete\" && echo \"======================================\" && echo \"\" && echo \"  QA state: $qa_state_file\" && echo \"\" && echo \"======================================\"'",
        continue_on_fail="true"
    ]

    // -----------------------------------------------------------------------
    // Edges (7 total)
    // -----------------------------------------------------------------------

    // Entry
    start -> container_check

    // Container check -> read QA state
    container_check -> read_qa_state

    // read_qa_state produces context.status = blocked|testing
    read_qa_state -> blocked_gate

    // Gate: blocked sessions exit immediately (human must resolve blockers)
    blocked_gate -> done     [label="blocked", condition="context.status=blocked"]
    // Gate: testing sessions enter the QA loop
    blocked_gate -> qa_loop  [label="testing", condition="context.status=testing"]

    // QA loop exits to final summary (either success or max cycles reached)
    qa_loop -> final_summary

    // Final summary -> done
    final_summary -> done
}
