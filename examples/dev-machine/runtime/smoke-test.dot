// smoke-test.dot -- Pre-Flight Validator
//
// Translates dev-machine-smoke-test.yaml (348 lines, 7 steps) into a DOT pipeline.
// Runs BEFORE starting the dev machine to confirm all required files,
// configurations, and robustness mechanisms are in place.
//
// Each check step uses continue_on_fail='true' so all checks run even when
// earlier ones fail. The final smoke_summary step aggregates results,
// prints a PASS/FAIL report, and fails hard if any check failed.
//
// Flow:
//   1. preflight:          verify .dev-machine/ directory exists (hard-fail)
//   2. check_files:        check required file existence and executability
//   3. check_dot_validity: validate .dot pipeline files parse cleanly
//   4. check_docker:       validate docker compose config (skipped if docker absent)
//   5. check_state:        check STATE.yaml required fields
//   6. check_robustness:   verify patterns present in scripts/infra/*.sh
//   7. smoke_summary:      aggregate all results, print report, hard-fail if any failed
//
// 9 nodes, 8 edges. Linear chain, no branching.
// No context variables required (smoke-test is self-contained).

digraph SmokeTest {
    graph [label="Dev Machine Pre-Flight Smoke Test"]
    rankdir=TB

    // -----------------------------------------------------------------------
    // Structural nodes
    // -----------------------------------------------------------------------

    start [shape=Mdiamond, label="Start"]
    done  [shape=Msquare,  label="Done"]

    // -----------------------------------------------------------------------
    // Step 0: Preflight -- must be run from the project root
    // Verifies that .dev-machine/ directory exists.
    // Hard-fail: no continue_on_fail. If the directory is absent, all
    // subsequent checks are meaningless and the pipeline must stop.
    // -----------------------------------------------------------------------

    preflight [
        shape=parallelogram,
        label="Preflight",
        tool_command="bash -c 'if [ ! -d .dev-machine ]; then echo \"ERROR: .dev-machine/ directory not found. Run this smoke test from the project root.\"; exit 1; fi; echo \"Preflight OK: .dev-machine/ directory found.\"'"
    ]

    // -----------------------------------------------------------------------
    // Step 1: File existence check
    // Verifies all required .dev-machine/ files are present and that
    // scripts are executable. Non-blocking: continue_on_fail so later
    // checks still run even if files are missing.
    // -----------------------------------------------------------------------

    check_files [
        shape=parallelogram,
        label="Check Files",
        tool_command="python3 scripts/pipeline/smoke-check-files.py",
        continue_on_fail="true"
    ]

    // -----------------------------------------------------------------------
    // Step 2: DOT file validity check
    // Validates that all .dot pipeline files in the runtime/ directory
    // parse cleanly using the DOT parser.
    // KEY ADAPTATION: original YAML step validated YAML recipes;
    // this step validates .dot pipeline files instead.
    // Non-blocking: continue_on_fail so subsequent checks still run.
    // -----------------------------------------------------------------------

    check_dot_validity [
        shape=parallelogram,
        label="Check DOT Validity",
        tool_command="python3 scripts/pipeline/smoke-check-dot-validity.py .dev-machine/runtime/*.dot",
        continue_on_fail="true"
    ]

    // -----------------------------------------------------------------------
    // Step 3: Docker config check
    // Validates docker compose config parses cleanly.
    // Skipped gracefully if docker is not available on PATH.
    // Non-blocking: continue_on_fail so docker absence cannot block the test.
    // -----------------------------------------------------------------------

    check_docker [
        shape=parallelogram,
        label="Check Docker",
        tool_command="python3 scripts/pipeline/smoke-check-docker.py",
        continue_on_fail="true"
    ]

    // -----------------------------------------------------------------------
    // Step 4: STATE.yaml content check
    // Verifies required fields (project_name, features, progress.current_epoch)
    // are present and populated in .dev-machine/STATE.yaml.
    // Non-blocking: continue_on_fail so subsequent checks still run.
    // -----------------------------------------------------------------------

    check_state [
        shape=parallelogram,
        label="Check State",
        tool_command="python3 scripts/pipeline/smoke-check-state.py",
        continue_on_fail="true"
    ]

    // -----------------------------------------------------------------------
    // Step 5: Robustness patterns check
    // Verifies that key robustness mechanisms are present in the infra scripts.
    // Checks for required patterns in scripts/infra/*.sh:
    //   - MAX_CONSECUTIVE_FAILURES in entrypoint
    //   - touch_heartbeat function in entrypoint
    //   - cf_mid_session detection in entrypoint
    //   - blocker aging logic in monitor script
    //   - heartbeat staleness check in watchdog script
    // Non-blocking: continue_on_fail so summary still aggregates all results.
    // -----------------------------------------------------------------------

    check_robustness [
        shape=parallelogram,
        label="Check Robustness",
        tool_command="python3 scripts/pipeline/smoke-check-robustness.py scripts/infra/*.sh",
        continue_on_fail="true"
    ]

    // -----------------------------------------------------------------------
    // Step 6: Smoke test summary -- aggregate all results, print report
    // Reads results from all previous check steps, prints a structured
    // PASS/FAIL report, and exits non-zero if any check failed.
    // Hard-fail: no continue_on_fail. This is the final gate.
    // -----------------------------------------------------------------------

    smoke_summary [
        shape=parallelogram,
        label="Smoke Summary",
        tool_command="python3 scripts/pipeline/smoke-summary.py"
    ]

    // -----------------------------------------------------------------------
    // Edges (8 total) -- linear chain, no branching
    // -----------------------------------------------------------------------

    start             -> preflight
    preflight         -> check_files
    check_files       -> check_dot_validity
    check_dot_validity -> check_docker
    check_docker      -> check_state
    check_state       -> check_robustness
    check_robustness  -> smoke_summary
    smoke_summary     -> done
}
